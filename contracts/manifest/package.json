{
  "name": "@omnifield/contract-manifest",
  "version": "0.1.0",
  "description": "Тонкий product-manifest контракт экосистемы Omnifield (omnifield.dev/v1). Источник правды — Zod; omnifield.schema.json выводится из неё (types-from-zod).",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./omnifield.schema.json": "./omnifield.schema.json"
  },
  "files": [
    "dist",
    "omnifield.schema.json",
    "examples",
    "README.md"
  ],
  "scripts": {
    "emit-schema": "node scripts/emit-schema.ts",
    "build": "pnpm run emit-schema && tsc -p tsconfig.json",
    "test": "node --test 'test/*.test.ts'",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "engines": {
    "node": ">=22.18"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "yaml": "^2.6.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
